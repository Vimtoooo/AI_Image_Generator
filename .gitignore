# --- Python & Testing Cache ---
**/__pycache__/
*.pyc
.pytest_cache/
.tox/
.coverage
htmlcov/

# --- IDEs & Local Workspaces ---
.vscode/
.idea/
*.swp
*.suo

# --- Virtual Environments (Never upload your local environment) ---
.venv/
venv/
env/
ENV/
build/
dist/

# --- Project Assets & Outputs (Keep repositories lightweight) ---
# Do not upload hundreds of megabytes of locally generated AI images
assets/generated_images/*
!assets/generated_images/.gitkeep
assets/youtube_profile_assets/

# --- Project Input Scripts & Documents ---
# Ignores your custom text files containing personal timestamps/prompts and documents
documents/
scripts/*.txt
!prompts/.gitkeep
!scripts/.gitkeep

# --- ComfyUI Local Configurations ---
apps/workflows/comfyui_api.json
